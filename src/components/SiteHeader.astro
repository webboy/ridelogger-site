---
import type { HomeMessages } from '../types/home';
import type { Locale } from '../i18n/config';
import { brandName } from '../i18n/config';
import { getAppUrl, getPartnerAppUrl } from '../config/public';
import { appCountryCodeFromPath } from '../config/countries';
import LanguageSwitcherCountry from './LanguageSwitcherCountry.astro';
import { GOOGLE_PLAY_APP_HREF, googlePlayBadgeImageSrc } from '../utils/googlePlayBadge';

interface Props {
	countryPath: string;
	locale: Locale;
	home: HomeMessages;
	variant?: 'default' | 'campaign';
	/** Full URL for primary app CTA when set (e.g. with marketing query params). */
	appHref?: string;
}

const { countryPath, locale, home, variant = 'default', appHref } = Astro.props;
const brand = brandName(locale);
const appCountry = appCountryCodeFromPath(countryPath);
const partnerUrl = getPartnerAppUrl();
const primaryAppHref = appHref ?? getAppUrl(locale, appCountry);
const isCampaign = variant === 'campaign';
const instance = import.meta.env.PUBLIC_INSTANCE || 'balkan';
const showPartnerLink = !isCampaign && instance !== 'global';
const showAndroidPromo = instance === 'balkan';
const playBadgeSrc = googlePlayBadgeImageSrc(locale);
const playBadgeAlt = home.footer.googlePlayBadgeAlt;
---

<header class="site-header">
	<a class="skip-link" href="#main">Skip to content</a>
	<div class="shell site-header__inner">
		<a class="brand" href={`/${countryPath}/`}>
			<img src="/brand/caloboo.png" width="40" height="40" alt="" />
			<span class="brand__name" data-brand-text>{brand}</span>
		</a>
		<div class="site-header__cta">
			{
				showPartnerLink && (
					<a class="btn btn--ghost" href={partnerUrl} rel="noopener noreferrer">
						<span data-hk="nav.partner">{home.nav.partner}</span>
					</a>
				)
			}
			<a class="btn btn--primary" data-app-link href={primaryAppHref} rel="noopener">
				<span data-hk="nav.openApp">{home.nav.openApp}</span>
			</a>
		</div>
		<div class="site-header__tools">
			<LanguageSwitcherCountry locale={locale} />
		</div>
	</div>
	{
		showAndroidPromo && (
			<div class="site-header__android-promo">
				<div class="shell site-header__android-promo-inner">
					<p class="site-header__android-promo-text muted" data-hk="nav.googlePlayPromo">
						{home.nav.googlePlayPromo}
					</p>
					<a
						class="site-header__android-promo-link"
						href={GOOGLE_PLAY_APP_HREF}
						target="_blank"
						rel="noopener noreferrer"
					>
						<img
							class="site-header__android-promo-badge"
							data-play-badge-src
							data-hk-alt="footer.googlePlayBadgeAlt"
							src={playBadgeSrc}
							alt={playBadgeAlt}
							width="646"
							height="250"
							decoding="async"
						/>
					</a>
				</div>
			</div>
		)
	}
</header>
