---
import type { HomeMessages } from '../types/home';
import type { Locale } from '../i18n/config';
import { brandName } from '../i18n/config';
import { countryPagesForInstance } from '../config/countries';
import { GOOGLE_PLAY_APP_HREF, googlePlayBadgeImageSrc } from '../utils/googlePlayBadge';

interface Props {
	countryPath: string;
	locale: Locale;
	home: HomeMessages;
	year: number;
}

const { countryPath, locale, home, year } = Astro.props;

const inst = (import.meta.env.PUBLIC_INSTANCE || 'balkan') as 'balkan' | 'global';
const countryPathsThisInstance = countryPagesForInstance(inst).map((c) => c.path);
const selling =
	home.footer.sellingCarsTitle &&
	home.footer.sellingPrivateLabel &&
	home.footer.sellingDealersLabel &&
	countryPathsThisInstance.includes(countryPath);

const sellingPrivateHref =
	inst === 'global' ? `/${countryPath}/private-sellers/` : `/${countryPath}/prodaja-auta/`;
const sellingDealersHref =
	inst === 'global' ? `/${countryPath}/auto-dealers/` : `/${countryPath}/auto-placevi/`;

const playBadgeSrc = googlePlayBadgeImageSrc(locale);
const playBadgeAlt = home.footer.googlePlayBadgeAlt;
---

<footer class="site-footer">
	<div class="shell site-footer__grid">
		<div>
			<strong data-brand-text>{brandName(locale)}</strong>
			<p class="muted" data-hk="footer.tagline">{home.footer.tagline}</p>
			<p class="muted" style="font-size: 0.95rem" data-hk="footer.note">{home.footer.note}</p>
			{
				/* Google Play bedž: samo balkan marketing sajt (ne global). */
				inst === 'balkan' && (
					<p class="site-footer__play-wrap">
						<a
							class="site-footer__play-link"
							href={GOOGLE_PLAY_APP_HREF}
							target="_blank"
							rel="noopener noreferrer"
							data-hk="footer.googlePlay"
						>
							<img
								class="site-footer__play-badge"
								src={playBadgeSrc}
								alt={playBadgeAlt}
								width="646"
								height="250"
								decoding="async"
							/>
						</a>
					</p>
				)
			}
			{
				selling && (
					<p class="muted site-footer__selling" style="margin-top: 1rem; font-size: 0.95rem">
						<strong data-hk="footer.sellingCarsTitle">{home.footer.sellingCarsTitle}</strong>
						<br />
						<a href={sellingPrivateHref} data-hk="footer.sellingPrivateLabel">
							{home.footer.sellingPrivateLabel}
						</a>
						{' · '}
						<a href={sellingDealersHref} data-hk="footer.sellingDealersLabel">
							{home.footer.sellingDealersLabel}
						</a>
					</p>
				)
			}
		</div>
		<div>
			<p class="muted" style="margin: 0 0 0.5rem">
				<a href={`/${countryPath}/privacy/`} data-hk="nav.privacy">{home.nav.privacy}</a>
				{' · '}
				<a href={`/${countryPath}/cookies/`} data-hk="nav.cookies">{home.nav.cookies}</a>
				{' · '}
				<a href={`/${countryPath}/terms/`} data-hk="nav.terms">{home.nav.terms}</a>
			</p>
			<p class="muted" style="margin: 0; font-size: 0.95rem">
				© {year} <span data-brand-text>{brandName(locale)}</span>
			</p>
		</div>
	</div>
</footer>
