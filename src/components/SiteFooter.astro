---
import type { HomeMessages } from '../types/home';
import type { Locale } from '../i18n/config';
import { brandName } from '../i18n/config';

interface Props {
	locale: Locale;
	home: HomeMessages;
	year: number;
}

const { locale, home, year } = Astro.props;
---

<footer class="site-footer">
	<div class="shell site-footer__grid">
		<div>
			<strong>{brandName(locale)}</strong>
			<p class="muted">{home.footer.tagline}</p>
			<p class="muted" style="font-size: 0.95rem">{home.footer.note}</p>
		</div>
		<div>
			<p class="muted" style="margin: 0 0 0.5rem">
				<a href={`/${locale}/privacy/`}>{home.nav.privacy}</a>
				{' · '}
				<a href={`/${locale}/cookies/`}>{home.nav.cookies}</a>
			</p>
			<p class="muted" style="margin: 0; font-size: 0.95rem">
				© {year} {brandName(locale)}
			</p>
		</div>
	</div>
</footer>
