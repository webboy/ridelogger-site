---
import type { ManagedDealerLandingContent } from '../../types/managedDealerLanding';

interface Props {
	content: ManagedDealerLandingContent;
	managedInquiryUrl: string | null;
	analyticsBrand: 'rl' | 'sk';
	pagePath: string;
	heroImageSrc?: string;
}

const {
	content: c,
	managedInquiryUrl,
	analyticsBrand,
	pagePath,
	heroImageSrc = '/images/problem-solution.jpg',
} = Astro.props;

const trustIcons = [
	'<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"/><circle cx="7" cy="17" r="2"/><path d="M9 17h6"/><circle cx="17" cy="17" r="2"/></svg>',
	'<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/><path d="M12 2v4"/></svg>',
	'<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/></svg>',
	'<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>',
];

const trustStripHeading = c.sectionLabels?.trustStripHeading ?? 'Highlights';
const faqHeading = c.sectionLabels?.faqHeading ?? 'FAQ';
---

<section class="hero">
	<div class="shell hero__grid">
		<div>
			<div class="hero__eyebrow">{c.hero.eyebrow}</div>
			<h1>{c.hero.headline}</h1>
			<p class="lead">{c.hero.sub}</p>
			<div class="hero__actions">
				{
					managedInquiryUrl ? (
						<a
							class="btn btn--primary"
							href={managedInquiryUrl}
							rel="noopener noreferrer"
							data-landing-cta="managed_inquiry_primary"
						>
							{c.hero.primaryCta}
						</a>
					) : (
						<span
							class="btn btn--primary"
							style="opacity: 0.55; cursor: not-allowed; pointer-events: none"
							title="Configure PUBLIC_MANAGED_DEALER_INQUIRY_URL"
							aria-disabled="true"
						>
							{c.hero.primaryCta}
						</span>
					)
				}
				<a class="btn btn--ghost" href={c.hero.secondaryHref} data-landing-cta="managed_diy_secondary">
					{c.hero.secondaryCta}
				</a>
			</div>
		</div>
		<div class="hero__art hero__art--image">
			<img
				src={heroImageSrc}
				width="1024"
				height="682"
				alt={c.meta.heroImageAlt}
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
		</div>
	</div>
</section>

<section class="section section--trust" aria-labelledby="managed-trust-title">
	<div class="shell">
		<h2 id="managed-trust-title" class="visually-hidden">{trustStripHeading}</h2>
		<div class="trust">
			{
				c.trustStrip.map((text, i) => (
					<div class={`trust__item trust__item--accent-${i % 4}`}>
						<span class="trust__icon" set:html={trustIcons[i % trustIcons.length]} />
						<div class="trust__text">
							<span class="trust__headline">{text}</span>
							<span class="trust__detail" />
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<section class="section" aria-labelledby="managed-intro-title">
	<div class="shell">
		<h2 id="managed-intro-title">{c.intro.headline}</h2>
		<p class="muted" style="max-width: 52rem; font-size: 1.05rem; line-height: 1.55">{c.intro.body}</p>
	</div>
</section>

<section class="section" aria-labelledby="managed-problem-title">
	<div class="shell">
		<div class="card" style="max-width: 52rem">
			<h2 id="managed-problem-title" style="margin-top: 0">{c.problem.headline}</h2>
			<p class="muted" style="margin: 0; line-height: 1.55">{c.problem.body}</p>
		</div>
	</div>
</section>

<section class="section" aria-labelledby="managed-before-title">
	<div class="shell">
		<h2 id="managed-before-title">{c.beforeSale.headline}</h2>
		<ul class="managed-list muted" style="max-width: 52rem; font-size: 1.05rem; line-height: 1.55">
			{c.beforeSale.items.map((item) => <li>{item}</li>)}
		</ul>
	</div>
</section>

<section class="section" aria-labelledby="managed-after-title">
	<div class="shell">
		<h2 id="managed-after-title">{c.afterSale.headline}</h2>
		<ul class="managed-list muted" style="max-width: 52rem; font-size: 1.05rem; line-height: 1.55">
			{c.afterSale.items.map((item) => <li>{item}</li>)}
		</ul>
	</div>
</section>

<section class="section" aria-labelledby="managed-pricing-title">
	<div class="shell">
		<div class="landing-offer">
			<h2 id="managed-pricing-title" style="margin: 0 0 0.75rem">{c.pricing.headline}</h2>
			<p class="landing-offer__eyebrow" style="margin-bottom: 0.5rem">{c.pricing.priceLine}</p>
			<p class="muted" style="margin: 0 0 1rem; max-width: 52rem; line-height: 1.55">{c.pricing.body}</p>
			<div class="landing-cta-row">
				{
					managedInquiryUrl ? (
						<a
							class="btn btn--primary"
							href={managedInquiryUrl}
							rel="noopener noreferrer"
							data-landing-cta="managed_inquiry_pricing"
						>
							{c.hero.primaryCta}
						</a>
					) : (
						<span
							class="btn btn--primary"
							style="opacity: 0.55; cursor: not-allowed; pointer-events: none"
							title="Configure PUBLIC_MANAGED_DEALER_INQUIRY_URL"
							aria-disabled="true"
						>
							{c.hero.primaryCta}
						</span>
					)
				}
				<a class="btn btn--ghost" href={c.closing.diyHref} data-landing-cta="managed_diy_from_pricing">
					{c.closing.diyCta}
				</a>
			</div>
			<p class="muted" style="margin: 1rem 0 0; font-size: 0.88rem; max-width: 48rem">{c.pricing.footnote}</p>
		</div>
	</div>
</section>

<section class="section" aria-labelledby="managed-privacy-title">
	<div class="shell">
		<div class="card" style="max-width: 52rem">
			<h2 id="managed-privacy-title" style="margin-top: 0">{c.privacy.headline}</h2>
			<p class="muted" style="margin: 0; line-height: 1.55">{c.privacy.body}</p>
		</div>
	</div>
</section>

<section class="section" aria-labelledby="managed-faq-title">
	<div class="shell">
		<h2 id="managed-faq-title">{faqHeading}</h2>
		<div class="landing-faq">
			{
				c.faq.items.map((item) => (
					<details>
						<summary>{item.q}</summary>
						<p>{item.a}</p>
					</details>
				))
			}
		</div>
	</div>
</section>

<section class="landing-closing" aria-labelledby="managed-close-title">
	<div class="shell">
		<h2 id="managed-close-title">{c.closing.headline}</h2>
		<p class="muted" style="max-width: 48rem; font-size: 1.05rem; line-height: 1.55">{c.closing.body}</p>
		<div class="landing-cta-row">
			{
				managedInquiryUrl ? (
					<a
						class="btn btn--primary"
						href={managedInquiryUrl}
						rel="noopener noreferrer"
						data-landing-cta="managed_inquiry_closing"
					>
						{c.hero.primaryCta}
					</a>
				) : (
					<span
						class="btn btn--primary"
						style="opacity: 0.55; cursor: not-allowed; pointer-events: none"
						title="Configure PUBLIC_MANAGED_DEALER_INQUIRY_URL"
						aria-disabled="true"
					>
						{c.hero.primaryCta}
					</span>
				)
			}
			<a class="btn btn--ghost" href={c.closing.diyHref} data-landing-cta="managed_diy_closing">
				{c.closing.diyCta}
			</a>
		</div>
	</div>
</section>

<script is:inline define:vars={{ analyticsBrand, pagePath }}>
	var attempts = 0;
	function emitLandingPageView() {
		attempts++;
		if (typeof window.gtag === 'function') {
			window.gtag('event', 'landing_page_view', {
				brand: analyticsBrand,
				segment: 'managed_dealer',
				page_path: pagePath,
			});
			return;
		}
		if (attempts < 20) setTimeout(emitLandingPageView, 300);
	}
	emitLandingPageView();

	document.addEventListener('click', function (e) {
		var t = e.target;
		if (!(t instanceof Element)) return;
		var el = t.closest('a[data-landing-cta]');
		if (!el) return;
		var ctaId = el.getAttribute('data-landing-cta');
		if (!ctaId) return;
		if (typeof window.gtag === 'function') {
			window.gtag('event', 'landing_cta_click', {
				brand: analyticsBrand,
				segment: 'managed_dealer',
				cta_id: ctaId,
				page_path: pagePath,
			});
		}
		if ((ctaId === 'managed_inquiry_primary' || ctaId === 'managed_inquiry_pricing' || ctaId === 'managed_inquiry_closing') && typeof window.fbq === 'function') {
			window.fbq('track', 'Contact');
		}
	});
</script>

<style>
	.visually-hidden {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}
	.managed-list {
		margin: 0;
		padding-left: 1.25rem;
	}
	.managed-list li {
		margin-bottom: 0.45rem;
	}
</style>
