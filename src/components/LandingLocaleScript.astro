---
import type { HomeMessages } from '../types/home';
import type { Locale } from '../i18n/config';

interface Props {
	homes: Record<Locale, HomeMessages>;
	defaultLocale: Locale;
}

const { homes, defaultLocale } = Astro.props;

const publicAppBase =
	typeof import.meta.env.PUBLIC_APP_URL === 'string' && import.meta.env.PUBLIC_APP_URL.length > 0
		? import.meta.env.PUBLIC_APP_URL
		: 'https://app.servisna-knjizica.com';

const storageInstance = (import.meta.env.PUBLIC_INSTANCE || 'balkan') as 'balkan' | 'global';

const init = {
	homes,
	defaultLocale,
	countryPath: null,
	publicAppBase,
	appCountryCode: null,
	storageInstance,
	lockDocumentSeo: false,
};
---

<script is:inline define:vars={{ init }}>
	globalThis.__MARKETING_LOCALE_INIT__ = init;
</script>
<script>
	import { initMarketingLocale } from '../scripts/marketingLocale';

	initMarketingLocale(globalThis.__MARKETING_LOCALE_INIT__);
</script>
