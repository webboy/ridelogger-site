---
import { LOCALES, LOCALE_LABELS, LOCALE_SHORT, LOCALE_FLAG, type Locale } from '../i18n/config';

interface Props {
	locale: Locale;
	/** Dropdown opens above the summary (e.g. footer — avoids clipping below the viewport). */
	panelUp?: boolean;
	/** With `panelUp`, center the panel on the trigger. */
	panelCenter?: boolean;
}

const { locale, panelUp = false, panelCenter = false } = Astro.props;
---

<details
	class:list={[
		'lang-switcher',
		panelUp && 'lang-switcher--panel-up',
		panelUp && panelCenter && 'lang-switcher--panel-center',
	]}
>
	<summary aria-label={LOCALE_LABELS[locale]}>
		<span class="lang-switcher__summary-inner">
			<img
				class="lang-switcher__flag"
				src={`/flags/${LOCALE_FLAG[locale]}.svg`}
				width="22"
				height="16"
				alt=""
				decoding="async"
				fetchpriority="high"
			/>
			<span class="lang-switcher__label lang-switcher__label--full">{LOCALE_LABELS[locale]}</span>
			<span class="lang-switcher__label lang-switcher__label--short" aria-hidden="true">{LOCALE_SHORT[locale]}</span>
		</span>
	</summary>
	<div class="lang-switcher__panel" role="navigation" aria-label="Language">
		{
			LOCALES.map((loc) => (
				<button
					type="button"
					class:list={['lang-switcher__btn', loc === locale && 'is-active']}
					data-locale-pick={loc}
					aria-current={loc === locale ? 'true' : undefined}
				>
					<img
						class="lang-switcher__flag"
						src={`/flags/${LOCALE_FLAG[loc]}.svg`}
						width="22"
						height="16"
						alt=""
						loading="lazy"
						decoding="async"
					/>
					<span class="lang-switcher__label lang-switcher__label--full">{LOCALE_LABELS[loc]}</span>
					<span class="lang-switcher__label lang-switcher__label--short" aria-hidden="true">{LOCALE_SHORT[loc]}</span>
				</button>
			))
		}
	</div>
</details>

<script is:inline>
	document.addEventListener('click', function (e) {
		var t = e.target;
		if (!(t instanceof Node)) return;
		document.querySelectorAll('details.lang-switcher[open]').forEach(function (el) {
			if (!el.contains(t)) {
				el.removeAttribute('open');
			}
		});
	});
</script>

<style>
	.lang-switcher__btn {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		width: 100%;
		padding: 0.5rem 0.75rem;
		border: 0;
		background: transparent;
		font: inherit;
		cursor: pointer;
		text-align: left;
		color: inherit;
	}
	.lang-switcher__btn:hover {
		background: rgba(0, 0, 0, 0.05);
	}
	.lang-switcher__btn.is-active {
		font-weight: 600;
	}
</style>
