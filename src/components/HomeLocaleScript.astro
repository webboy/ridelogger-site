---
import type { HomeMessages } from '../types/home';
import type { Locale } from '../i18n/config';
import type { LegalBundle } from '../i18n/loadLegal';

interface Props {
	homes: Record<Locale, HomeMessages>;
	defaultLocale: Locale;
	countryPath: string;
	publicAppBase: string;
	/** ISO country for PWA `?country=`; null to omit */
	appCountryCode: string | null;
	legalPage?: 'privacy' | 'cookies';
	legals?: Record<Locale, LegalBundle>;
	privacyUrl?: string;
}

const { homes, defaultLocale, countryPath, publicAppBase, appCountryCode, legalPage, legals, privacyUrl } =
	Astro.props;

const init = {
	homes,
	defaultLocale,
	countryPath,
	publicAppBase,
	appCountryCode,
	legalPage,
	legals,
	privacyUrl,
};
---

{/* define:vars + import must not be bundled into one non-module IIFE (breaks `import`). */}
<script is:inline define:vars={{ init }}>
	globalThis.__MARKETING_LOCALE_INIT__ = init;
</script>
<script>
	import { initMarketingLocale } from '../scripts/marketingLocale';

	initMarketingLocale(globalThis.__MARKETING_LOCALE_INIT__);
</script>
