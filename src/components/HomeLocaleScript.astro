---
import type { HomeMessages } from '../types/home';
import type { Locale } from '../i18n/config';
import { LOCALE_HREFLANG } from '../i18n/config';

interface Props {
	homes: Record<Locale, HomeMessages>;
	defaultLocale: Locale;
	countryPath: string;
	publicAppBase: string;
	/** ISO country for PWA `?country=`; null to omit */
	appCountryCode: string | null;
}

const { homes, defaultLocale, countryPath, publicAppBase, appCountryCode } = Astro.props;

const hrefLangMap: Record<string, string> = {};
for (const k of Object.keys(homes) as Locale[]) {
	hrefLangMap[k] = LOCALE_HREFLANG[k];
}
---

<script
	is:inline
	define:vars={{ homes, defaultLocale, countryPath, publicAppBase, hrefLangMap, appCountryCode }}
>
	(function () {
		var STORAGE_KEY = 'marketing_ui_locale';

		function brandLabel(loc) {
			return loc === 'sr-latn' || loc === 'sr-cyrl' || loc === 'hr'
				? 'Servisna Knjižica'
				: 'RideLogger';
		}

		function getPath(obj, path) {
			return path.split('.').reduce(function (o, k) {
				if (o == null) return o;
				var n = Number(k);
				return Number.isNaN(n) ? o[k] : o[n];
			}, obj);
		}

		function appHref(loc) {
			try {
				var u = new URL(publicAppBase);
				var tag = hrefLangMap[loc] || 'en';
				u.searchParams.set('lang', tag);
				if (appCountryCode && appCountryCode.length === 2) {
					u.searchParams.set('country', String(appCountryCode).toUpperCase());
				}
				return u.href;
			} catch (e) {
				return publicAppBase;
			}
		}

		function apply(loc) {
			var m = homes[loc];
			if (!m) return;

			document.querySelectorAll('[data-hk]').forEach(function (el) {
				var key = el.getAttribute('data-hk');
				if (!key) return;
				var v = getPath(m, key);
				if (typeof v === 'string') el.textContent = v;
			});

			document.querySelectorAll('[data-hk-alt]').forEach(function (el) {
				var key = el.getAttribute('data-hk-alt');
				if (!key) return;
				var v = getPath(m, key);
				if (typeof v === 'string') el.setAttribute('alt', v);
			});

			document.querySelectorAll('[data-app-link]').forEach(function (el) {
				el.setAttribute('href', appHref(loc));
			});

			document.querySelectorAll('[data-brand-text]').forEach(function (el) {
				el.textContent = brandLabel(loc);
			});

			document.querySelectorAll('[data-brand-line]').forEach(function (el) {
				var desc = getPath(m, 'meta.description');
				if (typeof desc === 'string') el.textContent = brandLabel(loc) + ' — ' + desc;
			});

			if (m.meta && typeof m.meta.title === 'string') {
				document.title = m.meta.title;
			}

		try {
			localStorage.setItem(STORAGE_KEY + '_' + countryPath, loc);
		} catch (e) {}

			document.documentElement.lang =
				loc === 'sr-latn' ? 'sr-Latn' : loc === 'sr-cyrl' ? 'sr-Cyrl' : loc;
		}

		function bindLocalePicks() {
			document.querySelectorAll('[data-locale-pick]').forEach(function (btn) {
				btn.addEventListener('click', function () {
					var v = btn.getAttribute('data-locale-pick');
					if (v && homes[v]) apply(v);
				});
			});
		}

		var loc = defaultLocale;
		try {
			var s = localStorage.getItem(STORAGE_KEY + '_' + countryPath);
			if (s && homes[s]) loc = s;
		} catch (e) {}

		function go() {
			apply(loc);
			bindLocalePicks();
		}

		if (document.readyState === 'loading') {
			document.addEventListener('DOMContentLoaded', go);
		} else {
			go();
		}
	})();
</script>
