---
import type { LegalBundle } from '../../i18n/loadLegal';

interface Props {
	legal: LegalBundle;
}

const { legal } = Astro.props;
const p = legal.privacy_v2;
---

<article class="legal-article">
	<p class="legal-meta">{p.updated_line}</p>
	<h1>{p.h1}</h1>

	<h2>{p.s1_title}</h2>
	<p>{p.s1_intro}</p>
	<ul>
		<li set:html={p.s1_li_company} />
		<li set:html={p.s1_li_address} />
		<li set:html={p.s1_li_phone} />
		<li set:html={p.s1_li_website} />
		<li set:html={p.s1_li_email} />
		<li set:html={p.s1_li_registry} />
	</ul>
	<p>{p.s1_dpo_intro}</p>
	<ul>
		<li set:html={p.s1_li_dpo} />
		<li set:html={p.s1_li_dpo_email} />
	</ul>

	<h2>{p.s2_title}</h2>
	<p>{p.s2_body}</p>

	<h2>{p.s3_title}</h2>
	<p>{p.s3_intro}</p>
	<ol>
		<li>
			<strong>{p.s3_cat1_title}</strong> — {p.s3_cat1_text}
		</li>
		<li>
			<strong>{p.s3_cat2_title}</strong> — {p.s3_cat2_text}
		</li>
		<li>
			<strong>{p.s3_cat3_title}</strong> — {p.s3_cat3_text}
		</li>
		<li>
			<strong>{p.s3_cat4_title}</strong> — {p.s3_cat4_text}
		</li>
		<li>
			<strong>{p.s3_cat5_title}</strong> — {p.s3_cat5_text}
		</li>
	</ol>

	<h2>{p.s4_title}</h2>
	<p>{p.s4_intro}</p>
	<ol>
		<li>
			<strong>{p.s4_p1_title}</strong>
			<ul>
				<li>{p.s4_p1_a}</li>
				<li>{p.s4_p1_b}</li>
			</ul>
		</li>
		<li>
			<strong>{p.s4_p2_title}</strong>
			<ul>
				<li>{p.s4_p2_a}</li>
				<li>{p.s4_p2_b}</li>
			</ul>
		</li>
		<li>
			<strong>{p.s4_p3_title}</strong> — {p.s4_p3_text}
		</li>
		<li>
			<strong>{p.s4_p4_title}</strong>
			<ul>
				<li>{p.s4_p4_a}</li>
				<li>{p.s4_p4_b}</li>
			</ul>
		</li>
	</ol>
	<p>{p.s4_consent_note}</p>

	<h2>{p.s5_title}</h2>
	<p>{p.s5_p1}</p>
	<p>{p.s5_p2}</p>
	<ul>
		<li>{p.s5_li1}</li>
		<li>{p.s5_li2}</li>
	</ul>
	<p>{p.s5_manage}</p>

	<h2>{p.s6_title}</h2>
	<p>{p.s6_intro}</p>
	<ul>
		<li>{p.s6_li1}</li>
		<li>{p.s6_li2}</li>
		<li>{p.s6_li3}</li>
		<li>{p.s6_li4}</li>
		<li>{p.s6_li5}</li>
	</ul>
	<p>{p.s6_outro}</p>

	<h2>{p.s7_title}</h2>
	<p>{p.s7_body}</p>

	<h2>{p.s8_title}</h2>
	<p>{p.s8_intro}</p>
	<ul>
		<li>{p.s8_li1}</li>
		<li>{p.s8_li2}</li>
		<li>{p.s8_li3}</li>
		<li>{p.s8_li4}</li>
	</ul>

	<h2>{p.s9_title}</h2>
	<p>{p.s9_intro}</p>
	<ul>
		<li>{p.s9_li1}</li>
		<li>{p.s9_li2}</li>
		<li>{p.s9_li3}</li>
		<li>{p.s9_li4}</li>
		<li>{p.s9_li5}</li>
	</ul>

	<h2>{p.s10_title}</h2>
	<p>{p.s10_intro}</p>
	<ul>
		<li>{p.s10_li1}</li>
		<li>{p.s10_li2}</li>
		<li>{p.s10_li3}</li>
		<li>{p.s10_li4}</li>
		<li>{p.s10_li5}</li>
		<li>{p.s10_li6}</li>
		<li>{p.s10_li7}</li>
	</ul>
	<p set:html={p.s10_request} />
	<p>{p.s10_complaint}</p>

	<h2>{p.s11_title}</h2>
	<p>{p.s11_body}</p>

	<h2>{p.s12_title}</h2>
	<p>{p.s12_body}</p>

	<h2>{p.s13_title}</h2>
	<p>{p.s13_intro}</p>
	<ul>
		<li set:html={p.s13_li_company} />
		<li set:html={p.s13_li_address} />
		<li set:html={p.s13_li_phone} />
		<li set:html={p.s13_li_website} />
		<li set:html={p.s13_li_email} />
	</ul>
</article>
