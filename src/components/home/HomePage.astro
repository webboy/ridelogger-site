---
import type { HomeMessages } from '../../types/home';
import type { Locale } from '../../i18n/config';
import { brandName } from '../../i18n/config';
import { getAppUrl } from '../../config/public';
import { appCountryCodeFromPath } from '../../config/countries';
import TrustStrip from './TrustStrip.astro';
import HowItWorks from './HowItWorks.astro';

interface Props {
	locale: Locale;
	home: HomeMessages;
	countryPath: string;
}

const { locale, home, countryPath } = Astro.props;
const brand = brandName(locale);
const appCountry = appCountryCodeFromPath(countryPath);

const testimonialAvatars = [
	'/images/testimonials/milos.jpg',
	'/images/testimonials/tijana.jpg',
	'/images/testimonials/momcilo.jpg',
	'/images/testimonials/jovana.jpg',
];
---

<section class="hero">
	<div class="shell hero__grid">
		<div>
			<div class="hero__eyebrow" data-hk="hero.eyebrow">{home.hero.eyebrow}</div>
			<h1 data-hk="hero.headline">{home.hero.headline}</h1>
			<p class="lead" data-hk="hero.sub">{home.hero.sub}</p>
			<div class="hero__actions">
				<a class="btn btn--primary" data-app-link href={getAppUrl(locale, appCountry)} rel="noopener">
					<span data-hk="hero.primaryCta">{home.hero.primaryCta}</span>
				</a>
				<a class="btn btn--ghost" href="#how"><span data-hk="hero.secondaryCta">{home.hero.secondaryCta}</span></a>
			</div>
			<p class="muted" style="margin-top: 1rem; font-size: 0.95rem" data-brand-line>
				{brand} — {home.meta.description}
			</p>
		</div>
		<div class="hero__art hero__art--image">
			<img
				src="/images/home-hero.jpg"
				width="1024"
				height="682"
				data-hk-alt="hero.imageAlt"
				alt={home.hero.imageAlt}
				loading="eager"
				fetchpriority="high"
				decoding="async"
			/>
		</div>
	</div>
</section>

<section class="section section--trust" aria-labelledby="trust-title">
	<div class="shell">
		<h2 id="trust-title" data-hk="trust.title">{home.trust.title}</h2>
		<TrustStrip items={home.trust.items} />
	</div>
</section>

<section class="section" aria-labelledby="problem-title">
	<div class="shell">
		<h2 id="problem-title" data-hk="problem.title">{home.problem.title}</h2>
		<figure class="problem-figure">
			<img
				src="/images/problem-solution.jpg"
				width="1024"
				height="682"
				data-hk-alt="problem.imageAlt"
				alt={home.problem.imageAlt}
				loading="lazy"
				decoding="async"
			/>
		</figure>
		<div class="split">
			<div class="card">
				<h3 style="margin: 0 0 0.5rem" data-hk="problem.problemTitle">{home.problem.problemTitle}</h3>
				<p class="muted" style="margin: 0" data-hk="problem.problemBody">{home.problem.problemBody}</p>
			</div>
			<div class="card">
				<h3 style="margin: 0 0 0.5rem" data-hk="problem.solutionTitle">{home.problem.solutionTitle}</h3>
				<p class="muted" style="margin: 0" data-hk="problem.solutionBody">{home.problem.solutionBody}</p>
			</div>
		</div>
	</div>
</section>

<section class="section section--how" id="how" aria-labelledby="how-title">
	<div class="shell">
		<h2 id="how-title" data-hk="how.title">{home.how.title}</h2>
		<p class="how__lead" data-hk="how.lead">{home.how.lead}</p>
		<HowItWorks steps={home.how.steps} />
	</div>
</section>

<section class="section">
	<div class="shell">
		<h2 data-hk="features.title">{home.features.title}</h2>
		<div class="features">
			{
				home.features.items.map((f, i) => (
					<div class="card">
						<h3 style="margin: 0 0 0.5rem" data-hk={`features.items.${i}.title`}>
							{f.title}
						</h3>
						<p class="muted" style="margin: 0" data-hk={`features.items.${i}.body`}>
							{f.body}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<section class="section">
	<div class="shell">
		<h2 data-hk="showcase.title">{home.showcase.title}</h2>
		<p class="muted" style="margin-top: 0" data-hk="showcase.body">
			{home.showcase.body}
		</p>
		<div class="showcase__grid" style="margin-top: 1rem">
			<div class="frame">
				<img
					src="/pwa-screenshots/wide.jpg"
					data-hk-alt="showcase.wideAlt"
					alt={home.showcase.wideAlt}
					loading="lazy"
					width="1024"
					height="540"
				/>
			</div>
			<div class="frame">
				<img
					src="/pwa-screenshots/narrow.jpg"
					data-hk-alt="showcase.narrowAlt"
					alt={home.showcase.narrowAlt}
					loading="lazy"
					width="682"
					height="1024"
				/>
			</div>
		</div>
	</div>
</section>

<section class="section" aria-labelledby="security-title">
	<div class="shell">
		<div class="card">
			<h2 id="security-title" style="margin-top: 0" data-hk="security.title">{home.security.title}</h2>
			<figure class="problem-figure">
				<img
					src="/images/security.jpg"
					width="1024"
					height="682"
					data-hk-alt="security.imageAlt"
					alt={home.security.imageAlt}
					loading="lazy"
					decoding="async"
				/>
			</figure>
			<p class="muted" style="margin: 0" data-hk="security.body">{home.security.body}</p>
		</div>
	</div>
</section>

<section class="section" aria-labelledby="testimonials-title">
	<div class="shell">
		<h2 id="testimonials-title" data-hk="testimonials.title">{home.testimonials.title}</h2>
		<div class="testimonials">
			{
				home.testimonials.items.map((t, i) => (
					<figure class="card quote">
						<div class="quote__header">
							<img
								class="quote__avatar"
								src={testimonialAvatars[i] ?? testimonialAvatars[0]}
								alt=""
								width="48"
								height="48"
								loading="lazy"
								decoding="async"
							/>
						</div>
						<blockquote cite="https://www.servisna-knjizica.com" style="margin: 0">
							“<span data-hk={`testimonials.items.${i}.quote`}>{t.quote}</span>”
						</blockquote>
						<footer>
							— <span data-hk={`testimonials.items.${i}.author`}>{t.author}</span>
						</footer>
					</figure>
				))
			}
		</div>
	</div>
</section>

<section class="section">
	<div class="shell">
		<div class="cta-band">
			<h2 style="margin: 0 0 0.5rem" data-hk="cta.title">{home.cta.title}</h2>
			<p style="margin: 0 0 1rem; opacity: 0.95" data-hk="cta.body">{home.cta.body}</p>
			<a class="btn btn--primary" data-app-link href={getAppUrl(locale, appCountry)} rel="noopener">
				<span data-hk="cta.button">{home.cta.button}</span>
			</a>
		</div>
	</div>
</section>
