---
import '../styles/global.css';
import {
	COUNTRY_PAGES,
	peerMarketingOrigin,
	type CountryPageConfig,
	type DeployInstance,
} from '../config/countries';
import { getHomeMessages, getAllHomeMessages } from '../i18n/loadHome';
import type { Locale } from '../i18n/config';
import { brandName } from '../i18n/config';
import LanguageSwitcherCountry from '../components/LanguageSwitcherCountry.astro';
import LandingLocaleScript from '../components/LandingLocaleScript.astro';
import CookieBanner from '../components/CookieBanner.astro';

const site = Astro.site;
if (!site) {
	throw new Error('Configure `site` in astro.config.mjs');
}
const selfOrigin = site.origin;
const peerOrigin = peerMarketingOrigin(selfOrigin);
const publicInstance = import.meta.env.PUBLIC_INSTANCE;
const selfIsBalkan =
	publicInstance === 'global'
		? false
		: publicInstance === 'balkan'
			? true
			: !selfOrigin.includes('ridelogger');
const uiLang = selfIsBalkan ? 'sr' : 'de';

const defaultLocale: Locale = selfIsBalkan ? 'sr-latn' : 'de';
const home = getHomeMessages(defaultLocale);
const homes = getAllHomeMessages();
const year = new Date().getFullYear();
const legalCountryPath = selfIsBalkan ? 'sr' : 'de';

function targetUrl(c: CountryPageConfig): string {
	const onSelf =
		(c.instance === 'balkan' && selfIsBalkan) || (c.instance === 'global' && !selfIsBalkan);
	const origin = onSelf ? selfOrigin : peerOrigin;
	return `${origin}/${c.path}/`;
}

function labelFor(c: CountryPageConfig): string {
	return selfIsBalkan ? c.names['sr-latn'] : c.names.de;
}

const sortLocale = selfIsBalkan ? 'sr-Latn' : 'de';
function sortByLabel(list: CountryPageConfig[]): CountryPageConfig[] {
	return [...list].sort((a, b) =>
		labelFor(a).localeCompare(labelFor(b), sortLocale, { sensitivity: 'base' }),
	);
}

function countriesInInstance(instance: DeployInstance): CountryPageConfig[] {
	return sortByLabel(COUNTRY_PAGES.filter((c) => c.instance === instance));
}

const europeCountries = countriesInInstance('global');
const balkanCountries = countriesInInstance('balkan');

/** Section titles on the map picker (fixed site branding, not translated). */
const groupLabels = {
	europe: 'RideLogger.com',
	balkan: 'servisna-knjizica.com',
};
---

<!doctype html>
<html lang={uiLang === 'sr' ? 'sr-Latn' : 'de'}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{home.meta.title}</title>
		<meta name="description" content={home.meta.description} />
		<link rel="canonical" href={new URL('/', site).href} />
	</head>
	<body class="picker-page">
		<header class="picker-hero" aria-label="Brand">
			<div class="picker-hero__inner">
				<img
					class="picker-hero__logo"
					src="/brand/caloboo.png"
					width="88"
					height="88"
					alt=""
				/>
				<p class="picker-hero__tagline" data-hk="landing.heroLine">
					{home.landing.heroLine}
				</p>
			</div>
		</header>

		<main class="picker-main">
			<div class="picker-list-panel">
				<div class="picker-groups">
					<section class="picker-group" aria-labelledby="picker-grp-europe">
						<h2 id="picker-grp-europe" class="picker-group-title">
							{groupLabels.europe}
						</h2>
						<ul class="picker-cards">
							{
								europeCountries.map((c) => (
									<li>
										<a class="picker-card" href={targetUrl(c)} data-path={c.path}>
											<img
												src={`/flags/${c.flagCode}.svg`}
												width="20"
												height="15"
												alt=""
											/>
											<span>{labelFor(c)}</span>
										</a>
									</li>
								))
							}
						</ul>
					</section>
					<section class="picker-group" aria-labelledby="picker-grp-balkan">
						<h2 id="picker-grp-balkan" class="picker-group-title">
							{groupLabels.balkan}
						</h2>
						<ul class="picker-cards">
							{
								balkanCountries.map((c) => (
									<li>
										<a class="picker-card" href={targetUrl(c)} data-path={c.path}>
											<img
												src={`/flags/${c.flagCode}.svg`}
												width="20"
												height="15"
												alt=""
											/>
											<span>{labelFor(c)}</span>
										</a>
									</li>
								))
							}
						</ul>
					</section>
				</div>
			</div>
		</main>

		<footer class="picker-site-footer site-footer picker-footer-minimal">
			<div class="shell picker-footer-minimal__inner">
				<div class="picker-footer-lang" aria-label="Language">
					<LanguageSwitcherCountry locale={defaultLocale} panelUp panelCenter />
				</div>
				<p class="muted picker-footer-minimal__links">
					<a href={`/${legalCountryPath}/privacy/`} data-hk="nav.privacy">{home.nav.privacy}</a>
					{' · '}
					<a href={`/${legalCountryPath}/cookies/`} data-hk="nav.cookies">{home.nav.cookies}</a>
				</p>
				<p class="muted picker-footer-minimal__copy">
					© {year} <span data-brand-text>{brandName(defaultLocale)}</span>
				</p>
			</div>
		</footer>

		<CookieBanner countryPath={legalCountryPath} locale={defaultLocale} />
		<LandingLocaleScript homes={homes} defaultLocale={defaultLocale} />

		<script is:inline define:vars={{ storageKey: 'sk_marketing_last_country' }}>
			(function () {
				var KEY = storageKey;
				var saved = null;
				try {
					saved = localStorage.getItem(KEY);
				} catch (e) {}

				function highlight(path) {
					document.querySelectorAll('.picker-card').forEach(function (el) {
						var p = el.getAttribute('data-path');
						el.classList.toggle('is-selected', p === path);
					});
				}

				if (saved) highlight(saved);

				document.querySelectorAll('.picker-card').forEach(function (el) {
					var path = el.getAttribute('data-path');
					el.addEventListener('click', function () {
						try {
							localStorage.setItem(KEY, path);
						} catch (err) {}
					});
				});
			})();
		</script>

		<style>
			.picker-page {
				min-height: 100vh;
				margin: 0;
				display: flex;
				flex-direction: column;
				font-family:
					system-ui,
					Segoe UI,
					Roboto,
					Helvetica,
					Arial,
					sans-serif;
				background: #f5f7fa;
				color: #1a2b3c;
			}
			.picker-hero {
				flex-shrink: 0;
				padding: 1.75rem 1.25rem 1.25rem;
				text-align: center;
			}
			.picker-hero__inner {
				max-width: 28rem;
				margin: 0 auto;
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 0.75rem;
			}
			.picker-hero__logo {
				display: block;
				width: 88px;
				height: 88px;
				object-fit: contain;
			}
			.picker-hero__tagline {
				margin: 0;
				font-size: clamp(1.05rem, 2.8vw, 1.2rem);
				font-weight: 600;
				letter-spacing: 0.02em;
				color: #1a2b3c;
				line-height: 1.35;
			}
			.picker-main {
				flex: 1;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 0.5rem 1.25rem 1.75rem;
				box-sizing: border-box;
				width: 100%;
			}
			.picker-list-panel {
				position: relative;
				width: 100%;
				max-width: min(920px, calc(100vw - 2rem));
				min-height: clamp(360px, 52vh, 580px);
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				padding: 2rem 1.75rem 2.25rem;
				border-radius: 16px;
				overflow: hidden;
				box-shadow: 0 12px 40px rgba(0, 0, 0, 0.1);
				background-color: #dce6f0;
				background-image: url('/images/europe-map.jpg');
				background-size: cover;
				background-position: center 35%;
				isolation: isolate;
			}
			.picker-list-panel::before {
				content: '';
				position: absolute;
				inset: 0;
				background: rgba(245, 247, 250, 0.36);
				z-index: 0;
			}
			.picker-list-panel > * {
				position: relative;
				z-index: 1;
			}
			.picker-groups {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1.35rem;
				width: 100%;
				max-width: 26rem;
			}
			.picker-group {
				width: 100%;
			}
			.picker-group-title {
				margin: 0 0 0.4rem;
				font-size: 0.62rem;
				font-weight: 700;
				letter-spacing: 0.12em;
				text-transform: uppercase;
				color: #5a6b7c;
				text-align: center;
			}
			.picker-cards {
				list-style: none;
				padding: 0;
				margin: 0;
				display: grid;
				grid-template-columns: repeat(2, minmax(0, 11rem));
				gap: 0.35rem 0.55rem;
				justify-content: center;
			}
			@media (max-width: 380px) {
				.picker-cards {
					grid-template-columns: 1fr;
				}
			}
			.picker-card {
				display: flex;
				align-items: center;
				justify-content: flex-start;
				gap: 0.35rem;
				padding: 0.28rem 0.45rem;
				min-height: 0;
				background: rgba(255, 255, 255, 0.38);
				border: 1px solid rgba(255, 255, 255, 0.55);
				border-radius: 8px;
				text-decoration: none;
				color: #1a2b3c;
				font-weight: 600;
				font-size: 0.72rem;
				line-height: 1.2;
				transition:
					background 0.15s ease,
					border-color 0.15s ease,
					box-shadow 0.15s ease;
				backdrop-filter: blur(6px);
				-webkit-backdrop-filter: blur(6px);
				box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
			}
			.picker-card:hover {
				background: rgba(255, 255, 255, 0.52);
				border-color: rgba(11, 79, 138, 0.28);
			}
			.picker-card.is-selected {
				background: rgba(11, 79, 138, 0.18);
				border-color: rgba(11, 79, 138, 0.45);
				box-shadow: 0 0 0 2px rgba(11, 79, 138, 0.2);
			}
			.picker-card img {
				flex-shrink: 0;
				width: 20px;
				height: 15px;
				object-fit: cover;
				border-radius: 2px;
				box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
			}
			.picker-site-footer {
				margin-top: auto;
				flex-shrink: 0;
				width: 100%;
			}
			.picker-footer-minimal__inner {
				text-align: center;
				padding: 1.25rem 1rem 1.5rem;
				position: relative;
			}
			/* Subtle language switcher above legal links */
			.picker-footer-lang {
				display: flex;
				justify-content: center;
				margin: 0 0 0.55rem;
				opacity: 0.62;
				font-size: 0.72rem;
				line-height: 1.2;
			}
			.picker-footer-lang:hover {
				opacity: 0.85;
			}
			.picker-footer-lang .lang-switcher {
				position: relative;
				z-index: 20;
			}
			.picker-footer-lang .lang-switcher summary {
				font-weight: 500;
				color: #5a6b7c;
			}
			.picker-footer-lang .lang-switcher__summary-inner {
				gap: 0.28rem;
			}
			.picker-footer-lang .lang-switcher__flag {
				width: 15px;
				height: auto;
				box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.06);
			}
			.picker-footer-lang .lang-switcher__label {
				font-size: inherit;
			}
			/* Panel position: global `.lang-switcher--panel-up` + component classes; only size tweaks here */
			.picker-footer-lang :global(.lang-switcher__panel) {
				min-width: 10.5rem;
				padding: 0.3rem;
				font-size: 0.78rem;
				box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
			}
			.picker-footer-lang .lang-switcher__btn {
				padding: 0.28rem 0.45rem;
				gap: 0.35rem;
			}
			.picker-footer-lang .lang-switcher__btn .lang-switcher__flag {
				width: 14px;
			}
			.picker-footer-minimal__links {
				margin: 0 0 0.5rem;
				font-size: 0.95rem;
			}
			.picker-footer-minimal__copy {
				margin: 0;
				font-size: 0.95rem;
			}
		</style>
	</body>
</html>
