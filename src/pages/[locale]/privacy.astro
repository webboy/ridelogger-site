---
import SiteLayout from '../../layouts/SiteLayout.astro';
import PrivacyArticle from '../../components/legal/PrivacyArticle.astro';
import { LOCALES, isLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { getLegal } from '../../i18n/loadLegal';
import { getHomeMessages } from '../../i18n/loadHome';

export function getStaticPaths() {
	return LOCALES.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!localeParam || !isLocale(localeParam)) {
	throw new Error(`Invalid locale: ${localeParam}`);
}

const locale = localeParam;
const legal = getLegal(locale);
const home = getHomeMessages(locale);

const title = legal.privacy_v2.meta_title;
const description = legal.privacy_v2.meta_description;
---

<SiteLayout locale={locale} title={title} description={description} home={home} pathSuffix="privacy">
	<div class="legal shell">
		<PrivacyArticle legal={legal} />
	</div>
</SiteLayout>
