---
import SiteLayout from '../../layouts/SiteLayout.astro';
import HomePage from '../../components/home/HomePage.astro';
import { LOCALES, brandName, isLocale } from '../../i18n/config';
import { getHomeMessages } from '../../i18n/loadHome';

export function getStaticPaths() {
	return LOCALES.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!localeParam || !isLocale(localeParam)) {
	throw new Error(`Invalid locale: ${localeParam}`);
}

const locale = localeParam;
const home = getHomeMessages(locale);
const title = `${brandName(locale)} — ${home.meta.title}`;
const description = home.meta.description;
---

<SiteLayout locale={locale} title={title} description={description} home={home} pathSuffix="">
	<HomePage locale={locale} home={home} />
</SiteLayout>
