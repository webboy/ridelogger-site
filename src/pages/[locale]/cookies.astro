---
import SiteLayout from '../../layouts/SiteLayout.astro';
import CookieArticle from '../../components/legal/CookieArticle.astro';
import { LOCALES, isLocale } from '../../i18n/config';
import type { Locale } from '../../i18n/config';
import { getLegal } from '../../i18n/loadLegal';
import { getHomeMessages } from '../../i18n/loadHome';

export function getStaticPaths() {
	return LOCALES.map((locale) => ({ params: { locale } }));
}

const localeParam = Astro.params.locale;
if (!localeParam || !isLocale(localeParam)) {
	throw new Error(`Invalid locale: ${localeParam}`);
}

const locale = localeParam;
const legal = getLegal(locale);
const home = getHomeMessages(locale);

const title = legal.cookie_policy.meta_title;
const description = legal.cookie_policy.meta_description;

const privacyUrl = new URL(`/${locale}/privacy/`, Astro.site).href;
---

<SiteLayout locale={locale} title={title} description={description} home={home} pathSuffix="cookies">
	<div class="legal shell">
		<CookieArticle legal={legal} privacyUrl={privacyUrl} />
	</div>
</SiteLayout>
