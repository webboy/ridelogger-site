---
import '../styles/global.css';
import CookieBanner from '../components/CookieBanner.astro';

const site = Astro.site;
const home = site ? new URL('/', site).href : '/';
const instance = (import.meta.env.PUBLIC_INSTANCE || 'balkan') as 'balkan' | 'global';
const countryPath = instance === 'global' ? 'de' : 'sr';
const locale = instance === 'global' ? 'de' : 'sr-latn';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>404 — Page not found</title>
		<meta http-equiv="refresh" content={`0;url=${home}`} />
		<link rel="canonical" href={home} />
	</head>
	<body
		style="font-family:system-ui,sans-serif;padding:2rem;max-width:40rem;margin:0 auto;line-height:1.5"
	>
		<h1>404</h1>
		<p>
			This page is not available. <a href={home}>Back to country picker</a>
		</p>
		<CookieBanner countryPath={countryPath} locale={locale} />
	</body>
</html>
