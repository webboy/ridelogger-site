---
import SiteLayout from '../../layouts/SiteLayout.astro';
import AutoSellerLanding from '../../components/auto-seller/AutoSellerLanding.astro';
import { countryPagesForInstance, getCountryByPath, type DeployInstance } from '../../config/countries';
import { appCountryCodeFromPath } from '../../config/countries';
import { getAllHomeMessages, getHomeMessages } from '../../i18n/loadHome';
import { getAppUrl, getDealerBonusInquiryUrl } from '../../config/public';
import { rlDealersCampaign } from '../../i18n/autoSellerCampaigns';

export function getStaticPaths() {
	const inst = (import.meta.env.PUBLIC_INSTANCE || 'balkan') as DeployInstance;
	if (inst !== 'global') return [];
	return countryPagesForInstance('global').map((c) => ({ params: { country: c.path } }));
}
const param = Astro.params.country;
const cfg = getCountryByPath(param ?? '');
if (!cfg) {
	throw new Error(`Unknown country: ${param}`);
}

const locale = cfg.defaultLocale;
const content = rlDealersCampaign(locale);
const home = getHomeMessages(locale);
const homes = getAllHomeMessages();
const appCountry = appCountryCodeFromPath(param ?? '');
const appUrl = getAppUrl(locale, appCountry);
const title = content.meta.title;
const description = content.meta.description;
---

<SiteLayout
	countryPath={cfg.path}
	locale={locale}
	title={title}
	description={description}
	home={home}
	homes={homes}
	lockMarketingSeo={true}
	pathSuffix="auto-dealers"
	headerVariant="campaign"
	headerAppHref={appUrl}
>
	<AutoSellerLanding
		content={content}
		appUrl={appUrl}
		dealerInquiryUrl={getDealerBonusInquiryUrl()}
		analyticsBrand="rl"
		analyticsSegment="dealer"
		pagePath={`/${param}/auto-dealers/`}
		heroImageSrc="/images/problem-solution.jpg"
	/>
</SiteLayout>
