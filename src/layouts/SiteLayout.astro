---
import '../styles/global.css';
import { type Locale } from '../i18n/config';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import CookieBanner from '../components/CookieBanner.astro';
import HomeLocaleScript from '../components/HomeLocaleScript.astro';
import type { HomeMessages } from '../types/home';
import type { LegalBundle } from '../i18n/loadLegal';
import { appCountryCodeFromPath } from '../config/countries';

interface Props {
	countryPath: string;
	locale: Locale;
	title: string;
	description: string;
	home: HomeMessages;
	/** URL tail after country: `privacy`, `cookies`, or campaign slugs e.g. `private-sellers`. */
	pathSuffix?: string;
	/** When set, enables client-side home copy switching + JSON for all locales. */
	homes?: Record<Locale, HomeMessages>;
	legalPage?: 'privacy' | 'cookies';
	legals?: Record<Locale, LegalBundle>;
	/** Canonical privacy URL (cookie policy body links). */
	privacyUrl?: string;
	/** Campaign landings: hide Partner link only; language switcher stays (like index). */
	headerVariant?: 'default' | 'campaign';
	/** Override primary app CTA href (e.g. UTM passthrough). */
	headerAppHref?: string;
	/** When `homes` is set for campaign pages, keep document title/description from SSR. */
	lockMarketingSeo?: boolean;
}

const {
	countryPath,
	locale,
	title,
	description,
	home,
	pathSuffix = '',
	homes,
	legalPage,
	legals,
	privacyUrl,
	headerVariant = 'default',
	headerAppHref,
	lockMarketingSeo = false,
} = Astro.props;

const publicAppBase =
	typeof import.meta.env.PUBLIC_APP_URL === 'string' && import.meta.env.PUBLIC_APP_URL.length > 0
		? import.meta.env.PUBLIC_APP_URL
		: 'https://app.servisna-knjizica.com';

function documentLang(loc: Locale): string {
	if (loc === 'sr-latn') return 'sr-Latn';
	if (loc === 'sr-cyrl') return 'sr-Cyrl';
	return loc;
}

const base = Astro.site;
if (!base) {
	throw new Error('Missing `site` in astro.config (needed for canonical/hreflang).');
}

function pageUrl(tail: string): string {
	return new URL(tail, base).href;
}

const pathTail =
	pathSuffix === '' ? `${countryPath}/` : `${countryPath}/${pathSuffix}/`;
const canonical = pageUrl(pathTail);
const year = new Date().getFullYear();
const appCountryCode = appCountryCodeFromPath(countryPath);
---

<!doctype html>
<html lang={documentLang(locale)}>
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonical} />
		<meta name="twitter:card" content="summary_large_image" />
	</head>
	<body>
		<SiteHeader
			countryPath={countryPath}
			locale={locale}
			home={home}
			variant={headerVariant}
			appHref={headerAppHref}
		/>
		<main id="main">
			<slot />
		</main>
		<SiteFooter countryPath={countryPath} locale={locale} home={home} year={year} />
		<CookieBanner countryPath={countryPath} locale={locale} />
		{
			homes && (
				<HomeLocaleScript
					homes={homes}
					defaultLocale={locale}
					countryPath={countryPath}
					publicAppBase={publicAppBase}
					appCountryCode={appCountryCode}
					lockDocumentSeo={lockMarketingSeo}
					legalPage={legalPage}
					legals={legals}
					privacyUrl={privacyUrl}
				/>
			)
		}
	</body>
</html>
