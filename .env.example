# Marketing site origin (canonical, sitemap, country picker cross-links).
PUBLIC_SITE_URL=https://www.servisna-knjizica.com

# Which country routes this build generates: balkan | global
PUBLIC_INSTANCE=balkan

# Public web app URL (PWA) used for primary CTAs ("Open app").
# Links add ?lang=<BCP-47>&country=<ISO> (e.g. ?lang=hr&country=HR); PWA reads them at boot.
PUBLIC_APP_URL=https://app.servisna-knjizica.com
